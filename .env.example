# Arenaiss environment variables.
# Server-side only. Do not prefix secrets with NEXT_PUBLIC_.
# Do not commit a real .env file; this file is a template.

# --- Renaiss OS Index API (partner credentials, server-side) ---
RENAISS_INDEX_API_KEY=rk_your_key_here
RENAISS_INDEX_API_SECRET=rsk_your_secret_here

# --- Simple demo account sessions (server-side cookie signing) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=replace_with_a_random_32_byte_secret

# --- Base URLs (override only if Renaiss changes them) ---
RENAISS_MARKETPLACE_BASE=https://api.renaiss.xyz
RENAISS_INDEX_BASE=https://api.renaissos.com

# --- OpenAI-compatible LLM for Card Passport AI (server-side only) ---
PASSPORT_AI_BASE_URL=https://v98store.com/v1
PASSPORT_AI_MODEL=deepseek-v4-flash
# PASSPORT_AI_API_KEY=your_provider_key_here
